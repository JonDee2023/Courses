WORKERS' TRAINING COURSES


CREATE TABLE users (
id VARCHAR(255) PRIMARY KEY NOT NULL,
firstname VARCHAR(255) NOT NULL,
lastname VARCHAR(255) NOT NULL,
sex VARCHAR(20) NOT NULL,
phonenum VARCHAR(15) NOT NULL,
email VARCHAR(255) NOT NULL,
unit TEXT NOT NULL,
dob DATE NOT NULL,
date_saved DATE NOT NULL,
induction_date DATE NULL,
role role default 'Enrolee',
password VARCHAR(255) NOT NULL,
faith_testimony TEXT NULL,
created_at TIMESTAMPTZ DEFAULT CURRENT_TIMESTAMP);

create type role as enum('Enrolee', 'Officer', 'Admin');

alter table users 
add column role role default 'Enrolee';

alter table users
add column date_saved date null;

alter table users
add column faith_testimony TEXT NULL;

CREATE EXTENSION IF NOT EXISTS pgcrypto;

CREATE TABLE user_logins(
login_id INT PRIMARY KEY NOT NULL,
user_id VARCHAR(150) NOT NULL,
login_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
logout_at TIMESTAMP DEFAULT NULL,
FOREIGN KEY (user_id)
        REFERENCES users(id)
        ON DELETE CASCADE
);

CREATE TABLE unit (

    unit_id SERIAL PRIMARY KEY,

    unit_name TEXT

);



